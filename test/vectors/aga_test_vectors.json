      "description": "Integer 100 (from scientific notation input 1e2)",
      "input_json": {"n": 100},
      "expected_canonical_string": "{\"n\":100}",
      "expected_sha256": "b39022c4ed96525c42cd0e7ce55308533962a655f1c19d5dac2f03e9dd995b2c"
    },
    {
