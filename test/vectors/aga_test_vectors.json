  "assertions": [
    "leaf:collision-prevention-A.hash != leaf:collision-prevention-B.hash",
    "Two events matching leaf:payload-exclusion metadata with ANY payloads produce same hash",
    "normalizeTimestamp('2026-03-18T15:22:09+00:00') == '2026-03-18T15:22:09Z'",
    "normalizeTimestamp('2026-03-18T15:22:09.000Z') == '2026-03-18T15:22:09Z'",
    "normalizeTimestamp('2026-03-18T15:22:09.123Z') == '2026-03-18T15:22:09.123Z'",
    "merkle:merkle-4-leaves.root verifiable via inclusion proof for any leaf",
    "All canonicalization vectors: JSON.canonicalize(input) == expected_canonical_string",
    "Ed25519: Sign(seed_key, message) produces identical 64-byte signature in Go and Python",
    "All receipt_vectors: Canonicalize(fields) == expected_canonical_without_signature",
    "All receipt_vectors: Ed25519.Sign(seed_key, canonical) == expected_signature_hex",
    "All receipt_vectors: SHA256(canonical_with_signature) == expected_chain_hash",
    "All canonicalization_edge_vectors: Canonicalize(input_json) == expected_canonical_string"
  ]
}
